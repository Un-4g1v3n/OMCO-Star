import boto3
import gzip
import pandas as pd

from io import BytesIO

s3 = boto3.client("s3")

bucket = "YOUR_BUCKET"
key = "072660ab-c588-4406-9468-72629b82f8cc/NCU01__2022_02_25_124733.csv.gz"

response = s3.get_object(
    Bucket=bucket,
    Key=key
)

compressed = response["Body"].read()

with gzip.GzipFile(fileobj=BytesIO(compressed)) as gz:

    df = pd.read_csv(gz)

print(df.head())
print(df.columns)
